{
  "name": "wamprx",
  "version": "2.2.0",
  "description": "Simple WAMP client library heavily relying on rxjs and TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "WAMP"
  ],
  "author": "Johan 't Hart",
  "license": "ISC",
  "dependencies": {
    "rxjs": "^7.8.2",
    "rxjs-utilities": "^2.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
